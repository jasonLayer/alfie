#!/usr/bin/env bash
# Alfie OS setup — installs on a fresh Mac with Claude Code
# Safe to re-run (idempotent).

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAUDE_DIR="$HOME/.claude"
SKILLS_DIR="$CLAUDE_DIR/skills"
MEMORY_DIR="$CLAUDE_DIR/memory"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }
fail() { echo -e "${RED}✗${NC} $*"; exit 1; }

echo ""
echo "  Alfie OS — setup"
echo "  ─────────────────"
echo ""

# ─── Step 1: Check Claude Code is installed ──────────────────────────────────
if [ ! -d "$CLAUDE_DIR" ]; then
  fail "Claude Code not found. Install from https://claude.ai/code and try again."
fi
ok "Claude Code found at $CLAUDE_DIR"

# ─── Step 2: Install gstack if not present ───────────────────────────────────
GSTACK_DIR="$SKILLS_DIR/gstack"
if [ -d "$GSTACK_DIR" ]; then
  warn "gstack already installed at $GSTACK_DIR — skipping"
else
  echo "Installing gstack..."
  git clone --single-branch --depth 1 https://github.com/garrytan/gstack.git "$GSTACK_DIR"
  cd "$GSTACK_DIR" && ./setup --quiet
  cd "$REPO_DIR"
  ok "gstack installed"
fi

# ─── Step 3: Symlink Alfie skills into ~/.claude/skills/ ─────────────────────
mkdir -p "$SKILLS_DIR"
LINKED=0
SKIPPED=0

for skill_dir in "$REPO_DIR/skills"/*/; do
  skill_name="$(basename "$skill_dir")"
  src="$REPO_DIR/skills/$skill_name/SKILL.md"
  dest_dir="$SKILLS_DIR/$skill_name"
  dest="$dest_dir/SKILL.md"

  [ -f "$src" ] || continue

  mkdir -p "$dest_dir"

  if [ -L "$dest" ]; then
    # Already a symlink — update it
    ln -snf "$src" "$dest"
    SKIPPED=$((SKIPPED + 1))
  elif [ -f "$dest" ]; then
    # Real file exists — back it up and replace with symlink
    mv "$dest" "$dest.bak"
    ln -snf "$src" "$dest"
    warn "$skill_name: existing SKILL.md backed up to SKILL.md.bak"
    LINKED=$((LINKED + 1))
  else
    ln -snf "$src" "$dest"
    LINKED=$((LINKED + 1))
  fi
done

ok "Skills linked: $LINKED new, $SKIPPED already up-to-date"

# ─── Step 4: Symlink extension skills into ~/.claude/skills-ext/ ─────────────
SKILLS_EXT_DIR="$CLAUDE_DIR/skills-ext"
mkdir -p "$SKILLS_EXT_DIR"
EXT_LINKED=0
EXT_SKIPPED=0

for skill_dir in "$REPO_DIR/skills-ext"/*/; do
  [ -d "$skill_dir" ] || continue
  skill_name="$(basename "$skill_dir")"
  src="$REPO_DIR/skills-ext/$skill_name"
  dest="$SKILLS_EXT_DIR/$skill_name"

  if [ -L "$dest" ]; then
    ln -snf "$src" "$dest"
    EXT_SKIPPED=$((EXT_SKIPPED + 1))
  elif [ -d "$dest" ]; then
    warn "skills-ext/$skill_name: real directory exists — skipping"
  else
    ln -snf "$src" "$dest"
    EXT_LINKED=$((EXT_LINKED + 1))
  fi
done

ok "Extension skills linked: $EXT_LINKED new, $EXT_SKIPPED already up-to-date"

# ─── Step 6: Copy memory templates (no overwrite) ────────────────────────────
mkdir -p "$MEMORY_DIR"
COPIED=0

for src in "$REPO_DIR/memory"/*.md; do
  [ -f "$src" ] || continue
  fname="$(basename "$src")"
  dest="$MEMORY_DIR/$fname"
  if [ -f "$dest" ]; then
    : # Already exists — skip (user may have personalized it)
  else
    cp "$src" "$dest"
    ok "Memory: copied $fname"
    COPIED=$((COPIED + 1))
  fi
done

[ "$COPIED" -eq 0 ] && warn "Memory templates already present — skipped (no overwrite)"

# ─── Step 7: Generate ~/.claude/CLAUDE.md from template ─────────────────────
CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
TMPL="$REPO_DIR/CLAUDE.md.tmpl"

if [ -f "$CLAUDE_MD" ]; then
  warn "~/.claude/CLAUDE.md already exists — skipping (won't overwrite)"
else
  echo ""
  echo "Let's personalize your Alfie install."
  echo ""

  read -rp "  Your name (e.g. Jane Smith): " USER_NAME
  read -rp "  Your email: " USER_EMAIL
  read -rp "  Your venture(s) (e.g. Acme, SideProject): " USER_VENTURES

  echo ""

  NAME="$USER_NAME" EMAIL="$USER_EMAIL" VENTURES="$USER_VENTURES" \
    envsubst '${NAME} ${EMAIL} ${VENTURES}' < "$TMPL" > "$CLAUDE_MD"

  ok "Generated ~/.claude/CLAUDE.md"
fi

# ─── Done ────────────────────────────────────────────────────────────────────
echo ""
echo "  ─────────────────────────────"
echo "  Alfie OS installed!"
echo ""
echo "  Open Claude Code and type /brainstorm to get started."
echo ""
